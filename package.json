{
  "name": "vite-plugin-makefile",
  "version": "0.0.1",
  "description": "Vite plugin that converts Makefile targets into vite-plus tasks",
  "keywords": [
    "makefile",
    "plugin",
    "task-runner",
    "vite",
    "vite-plus"
  ],
  "homepage": "https://github.com/kazupon/vite-plugin-makefile#readme",
  "bugs": {
    "url": "https://github.com/kazupon/vite-plugin-makefile/issues"
  },
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/vite-plugin-makefile.git"
  },
  "funding": "https://github.com/sponsors/kazupon",
  "files": [
    "binding/index.d.ts",
    "binding/index.js",
    "dist/*"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp run build:binding && vp pack",
    "build:binding": "napi build --release --platform --package makefile-binding --dts index.d.ts --js index.js --esm -o binding",
    "knip": "knip",
    "release": "bumpp \"package.json\" \"npm/**/package.json\" --commit \"release: v\" --all --push --tag",
    "dev": "vp pack --watch",
    "test": "cargo test && vp test",
    "check": "cargo check && vp check && knip",
    "fmt": "cargo fmt && vp fmt",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "obug": "^2.1.1"
  },
  "devDependencies": {
    "@kazupon/eslint-plugin": "^0.7.1",
    "@kazupon/vp-config": "^0.1.0",
    "@napi-rs/cli": "^3.0.0-alpha.86",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "knip": "^6.1.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.14"
  },
  "napi": {
    "binaryName": "makefile-binding",
    "packageName": "vite-plugin-makefile",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
